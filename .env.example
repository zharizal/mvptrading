# Root-level env file read by docker-compose.
# Copy to `.env` and edit for your environment.

# Backend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SYMBOL=BTCUSDT
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=
OPENROUTER_APP_NAME=mvptrading
LLM_MODEL=anthropic/claude-haiku-4.5
POLL_INTERVAL_SECONDS=5
POLL_INTERVAL_FOREX_SECONDS=30

# TwelveData (forex + XAU/gold). Get a free key at https://twelvedata.com/
TWELVEDATA_API_KEY=
TWELVEDATA_BASE_URL=https://api.twelvedata.com

# SQLite database file path.
DB_PATH=data/mvptrading.db

# Frontend (must be reachable from the user's browser)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/market
