APP_HOST=127.0.0.1
APP_PORT=8000
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
SYMBOL=BTCUSDT
# Optional: set to enable AI-generated reasoning. If empty, falls back to rule-based narrative.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional OpenRouter attribution headers.
OPENROUTER_REFERER=
OPENROUTER_APP_NAME=mvptrading
POLL_INTERVAL_SECONDS=5
POLL_INTERVAL_FOREX_SECONDS=30
LLM_MODEL=anthropic/claude-haiku-4.5

# TwelveData (for XAU + forex). Get a free key at https://twelvedata.com/
TWELVEDATA_API_KEY=
TWELVEDATA_BASE_URL=https://api.twelvedata.com

# SQLite database file (relative to backend/ or absolute).
DB_PATH=data/mvptrading.db
